# ==============================================================================
# ENVIRONMENT VARIABLES TEMPLATE
# ==============================================================================
# Panduan: 
# 1. Salin (copy) file ini dan ubah namanya menjadi ".env.local"
# 2. Ganti nilai-nilai di bawah ini dengan kredensial asli Anda.
# 3. JANGAN PERNAH menyimpan password asli di dalam file .env.example ini!

# -- KONEKSI DATABASE (AZURE POSTGRESQL) --
# Format: "postgresql://[USERNAME]:[PASSWORD]@[HOST]:[PORT]/[DATABASE]?uselibpqcompat=true&sslmode=require"
# Contoh: 
DATABASE_URL="postgresql://db_user_anda:password_rahasia_anda@nama-server.postgres.database.azure.com/postgres?uselibpqcompat=true&sslmode=require"

# -- MODEL API URL --
# Masukkan endpoint API untuk model analitik AI Azure Anda
AZURE_MODEL_URL="https://[NAMA-APP-AZURE].azurewebsites.net/api/analyze"

# -- NEXTAUTH CONFIG --
# NEXTAUTH_SECRET harus berupa string acak yang panjang (digunakan untuk enkripsi sesi)
# Anda bisa membuatnya dengan menjalankan perintah: openssl rand -base64 32
NEXTAUTH_SECRET="masukkan_string_acak_rahasia_disini_jangan_diberitahu_siapapun"

# URL utama aplikasi Anda (Gunakan http://localhost:3002 saat pengembangan lokal)
NEXTAUTH_URL="http://localhost:3002"